# Coverage configuration for CI (hardware tests excluded)
# Extends pyproject.toml settings with additional omissions for files
# that are only exercised by hardware tests.

[run]
source = src
branch = true
omit =
    */tests/*
    */__init__.py
    */abstract_energy_profiler.py
    */mac_energy_profiler.py
    */carbon_energy_profiler.py

[report]
show_missing = true
skip_covered = false
exclude_also =
    def __repr__
    def __str__
    raise NotImplementedError
    if __name__ == .__main__.:
    @(abc\.)?abstractmethod
    TYPE_CHECKING
